{
  "mcps": [
    {
      "id": "docs-core",
      "name": "woddi-ai Core Docs",
      "description": "Lokale Architektur-, Release- und Setup-Dokumentation des Core-Repos",
      "kind": "docs",
      "enabled": true,
      "path": "/srv/http/woddi-ai",
      "patterns": [
        "README.md",
        "docs/**/*.md",
        "releases/*.md"
      ]
    },
    {
      "id": "docs-sat-docs",
      "name": "Satellite Docs",
      "description": "Lokale Dokumentation und Python-Code des Docs-Satelliten",
      "kind": "docs",
      "enabled": true,
      "path": "/srv/http/woddi-ai-satellite-docs",
      "patterns": [
        "README.md",
        "config/**/*.json",
        "app/**/*.py",
        "scripts/**/*.sh"
      ]
    },
    {
      "id": "files-main",
      "name": "Workspace Files",
      "description": "Dateibasiertes MCP fuer Core, Satelliten und die Control-App",
      "kind": "files",
      "enabled": true,
      "roots": [
        {
          "id": "woddi-core",
          "name": "woddi-ai Core",
          "path": "/srv/http/woddi-ai",
          "patterns": [
            "README.md",
            "docs/**/*.md",
            "config/**/*.json",
            "core/**/*.py",
            "modules/**/*.py",
            "satellite/**/*.py",
            "systemd/**/*.tpl"
          ]
        },
        {
          "id": "satellite-docs",
          "name": "Satellite Docs",
          "path": "/srv/http/woddi-ai-satellite-docs",
          "patterns": [
            "README.md",
            "config/**/*.json",
            "app/**/*.py",
            "scripts/**/*.sh"
          ]
        },
        {
          "id": "satellite-netbox",
          "name": "Satellite NetBox",
          "path": "/srv/http/woddi-ai-satellite-netbox",
          "patterns": [
            "README.md",
            "app/**/*.py",
            "scripts/**/*.sh"
          ]
        },
        {
          "id": "control",
          "name": "woddi-ai Control",
          "path": "/srv/http/woddi-ai-control",
          "patterns": [
            "README.md",
            "config/**/*.json",
            "app/**/*.py",
            "web/**/*.html",
            "web/**/*.js",
            "systemd/**/*.tpl",
            "scripts/**/*.sh"
          ]
        }
      ]
    },
    {
      "id": "netbox-main",
      "name": "NetBox",
      "description": "NetBox API MCP fuer Inventory, IPAM und Objekt-Explorer",
      "kind": "netbox",
      "enabled": true,
      "base_url": "https://netbox-dev.global.cloud.sap/api",
      "token": "",
      "token_env": "",
      "cache_ttl_seconds": 45,
      "timeout_seconds": 12
    },
    {
      "id": "remote-example",
      "name": "Remote MCP Beispiel",
      "description": "Beispiel fuer einen externen MCP auf einem anderen Host oder in Docker",
      "kind": "remote_http",
      "enabled": false,
      "base_url": "http://remote-host:8080",
      "execute_path": "/execute",
      "health_path": "/health",
      "bearer_token_env": "REMOTE_MCP_TOKEN",
      "timeout_seconds": 15
    }
  ]
}
