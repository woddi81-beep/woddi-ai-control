MONO_APP_NAME=woddi-ai-mono
MONO_HOST=0.0.0.0
MONO_PORT=8095
MONO_LOG_LEVEL=INFO
MONO_LOG_FILE=logs/woddi-ai-mono.log
MONO_RUNTIME_CONFIG_PATH=config/runtime.json

# Remote OpenAI-compatible LLM endpoint
MONO_LLM_BASE_URL=http://127.0.0.1:11434/v1
MONO_LLM_MODEL=llama3.2:latest
MONO_LLM_FALLBACK_MODEL=
MONO_LLM_API_KEY=
MONO_LLM_TIMEOUT_SECONDS=60
MONO_LLM_MAX_TOKENS=1400

# Chat and caching
MONO_SYSTEM_PROMPT_PATH=config/system_prompt.txt
MONO_CHAT_HISTORY_LIMIT=12
MONO_CHAT_RATE_LIMIT_PER_MINUTE=90
MONO_CONTEXT_MAX_CHARS=18000
MONO_DOCS_TOP_K=4
MONO_DOCS_SEARCH_CACHE_TTL_SECONDS=120
MONO_DOCS_ANSWER_CACHE_TTL_SECONDS=120
MONO_NETBOX_CACHE_TTL_SECONDS=45
MONO_NETBOX_TIMEOUT_SECONDS=12

# Docs MCPs
MONO_DOCS_SOURCES_PATH=config/docs_sources.json
MONO_DOCS_CACHE_DIR=data/cache
MONO_DOCS_ALLOW_OUTSIDE_PROJECT=0

# NetBox MCP
MONO_NETBOX_BASE_URL=https://netbox-dev.global.cloud.sap/api
MONO_NETBOX_TOKEN=
MONO_NETBOX_TOKEN_ENV=
