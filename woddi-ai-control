#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

if [[ -x "${SCRIPT_DIR}/.venv/bin/python" ]]; then
  cd "${SCRIPT_DIR}"
  exec "${SCRIPT_DIR}/.venv/bin/python" -m app.cli "$@"
fi

if command -v python3 >/dev/null 2>&1; then
  cd "${SCRIPT_DIR}"
  exec python3 -m app.cli "$@"
fi

if command -v python >/dev/null 2>&1; then
  cd "${SCRIPT_DIR}"
  exec python -m app.cli "$@"
fi

printf '[control][error] Weder .venv/bin/python noch python3/python verfuegbar.\n' >&2
exit 2
